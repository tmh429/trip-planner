# ==========================================
# Trip Planner 前端配置
# 复制此文件为 .env 并填入你的实际值
# ==========================================

# --- 后端 API 地址 ---
VITE_API_BASE_URL=http://localhost:8000

# --- 高德地图 Web API Key（跟后端 AMAP_API_KEY 同一个）---
VITE_AMAP_WEB_KEY=your_amap_web_key_here

# --- 高德地图 JS API Key（前端地图组件专用，需单独申请）---
# 申请地址: https://lbs.amap.com/api/jsapi-v2/summary
VITE_AMAP_WEB_JS_KEY=your_amap_web_js_key_here
