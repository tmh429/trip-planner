# ==========================================
# Trip Planner 后端配置
# 复制此文件为 .env 并填入你的实际值
# ==========================================

# --- LLM 配置 ---
# 模型名称（任意 OpenAI 兼容模型均可）
LLM_MODEL_ID=your-model-name
# API 密钥
LLM_API_KEY=your-api-key-here
# API 服务地址
LLM_BASE_URL=your-api-base-url
# 请求超时（秒）
LLM_TIMEOUT=300
# 最大输出 token 数
LLM_MAX_TOKENS=4096

# --- 服务器配置 ---
HOST=0.0.0.0
PORT=8000

# --- CORS 配置（前端地址，逗号分隔）---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- 代理设置（公司网络可能需要）---
# NO_PROXY=localhost,127.0.0.1

# --- 日志级别 ---
LOG_LEVEL=INFO

# --- Unsplash 图片搜索 API ---
# 申请地址: https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# --- 高德地图 API ---
# 申请地址: https://lbs.amap.com/api/webservice/summary
AMAP_API_KEY=your_amap_api_key_here
